<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>自己紹介</title>

<style>

body{
    font-family: sans-serif;
    background: linear-gradient(135deg,#4facfe,#00f2fe);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    margin:0;
}

.card{
    background:white;
    padding:30px;
    border-radius:15px;
    width:320px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

h1{
    margin-top:0;
}

.point{
    font-size:40px;
    animation:float 2s infinite ease-in-out;
}

@keyframes float{
    0%{transform:translateY(0)}
    50%{transform:translateY(-8px)}
    100%{transform:translateY(0)}
}

button{
    padding:10px 20px;
    border:none;
    border-radius:8px;
    background:#4facfe;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.2s;
}

button:hover{
    transform:scale(1.1);
    background:#2f8be6;
}

#intro{
    margin-top:20px;
    font-size:18px;
    min-height:60px;
}

</style>
</head>

<body>

<div class="card">

<div class="point">⭐</div>

<h1>自己紹介</h1>

<button onclick="showIntro()">クリック</button>

<div id="intro"></div>

</div>

<script>

const text = "はしばです。プログラミングやゲームが好きです。これからいろいろ作っていきたいです！";
let index = 0;

function showIntro(){

const intro = document.getElementById("intro");
intro.innerHTML = "";
index = 0;

const timer = setInterval(()=>{
intro.innerHTML += text[index];
index++;

if(index >= text.length){
clearInterval(timer);
}

},60);

}

</script>

</body>
</html>
